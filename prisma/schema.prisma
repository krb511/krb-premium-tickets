// 1. تحديد مزود قاعدة البيانات
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 2. تحديد المولد (لا تغيّر هذا)
generator client {
  provider = "prisma-client-js"
}

// 3. جدول التذاكر
model Ticket {
  id        String   @id @default(uuid())
  guildId   String
  userId    String
  category  String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
}
