generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model GuildConfig {
  guildId           String      @id
  ticketCategory    String?
  logChannelId      String?
  transcriptChannel String?
  managerRoles      String      @default("[]") // JSON Array
  supportRoles      String      @default("[]") // JSON Array
  maxOpenTickets    Int         @default(1)
  welcomeMessage    String      @default("مرحباً بك في الدعم الفني، سيتم الرد عليك قريباً.")
  ticketCounter     Int         @default(0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  tickets           Ticket[]
  blacklists        Blacklist[]
  auditLogs         AuditLog[]
}

model Ticket {
  id          String      @id @default(uuid())
  guildId     String
  channelId   String      @unique
  ownerId     String
  status      String      @default("OPEN") // OPEN, CLAIMED, CLOSED
  priority    String      @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  claimedById String?
  category    String
  tags        String      @default("[]") // JSON Array
  createdAt   DateTime    @default(now())
  closedAt    DateTime?
  guild       GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@index([ownerId])
  @@index([guildId, status])
}

model Blacklist {
  id        String      @id @default(uuid())
  guildId   String
  userId    String
  reason    String?
  addedBy   String
  createdAt DateTime    @default(now())
  guild     GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@unique([guildId, userId])
}

model AuditLog {
  id        String      @id @default(uuid())
  guildId   String
  action    String      // TICKET_CREATE, TICKET_CLOSE, USER_BLACKLISTED
  userId    String
  details   String      // JSON payload
  createdAt DateTime    @default(now())
  guild     GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@index([guildId])
}
