generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Ticket {
  id        String   @id @default(uuid())
  guildId   String
  userId    String
  category  String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
}

model GuildConfig {
  guildId String @id
  prefix  String @default("!")
}
